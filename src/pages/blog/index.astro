---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";

import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import FormattedDate from "../../components/FormattedDate.astro";

import {
	SITE_TITLE,
	SITE_DESCRIPTION
} from "../../consts";

const posts = (await getCollection("blog")).sort(
	(a, b) =>
		b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const featuredPost =
	posts.find((post) => post.data.featured) ??
	posts[0];

const regularPosts = featuredPost
	? posts.filter((post) => post.id !== featuredPost.id)
	: [];
---

<!doctype html>

<html lang="pt-BR">

<head>

	<BaseHead
		title={`Blog | ${SITE_TITLE}`}
		description={SITE_DESCRIPTION}
	/>

</head>

<body>

	<Header />

	<main class="page">

		<section class="hero">

			<span class="hero-label">
				BLOG
			</span>

			<h1>
				Artigos do PagoMeia
			</h1>

			<p>
				Conteúdos sobre filmes, séries, animes, games,
				listas, curiosidades e tudo que faz parte do
				universo do canal.
			</p>

			<div class="search-wrapper">

				<svg
					class="search-icon"
					viewBox="0 0 24 24"
					aria-hidden="true"
				>
					<path
						d="m21 21-4.35-4.35m2.35-5.65a8 8 0 1 1-16 0 8 8 0 0 1 16 0Z"
					></path>
				</svg>

				<input
					id="article-search"
					type="search"
					placeholder="Pesquisar artigos..."
					autocomplete="off"
					aria-label="Pesquisar artigos"
				/>

			</div>

			<p class="result-count" id="result-count">
				{posts.length === 1
					? "1 artigo publicado"
					: `${posts.length} artigos publicados`}
			</p>

		</section>

		{
			featuredPost && (

				<section
					class="featured-section searchable-post"
					data-search={`
						${featuredPost.data.title}
						${featuredPost.data.description}
						${featuredPost.data.category}
						${featuredPost.data.tags.join(" ")}
					`}
				>

					<a
						class="featured-card"
						href={`/blog/${featuredPost.id}/`}
					>

						<div class="featured-image">

							{
								featuredPost.data.heroImage ? (

									<Image
										src={featuredPost.data.heroImage}
										width={1400}
										height={800}
										alt={featuredPost.data.title}
									/>

								) : (

									<div class="image-placeholder">
										PagoMeia
									</div>

								)
							}

							<span class="featured-badge">
								DESTAQUE
							</span>

						</div>

						<div class="featured-content">

							<div class="featured-meta">

								<span class="category">
									{featuredPost.data.category}
								</span>

								<div class="date-info">

									<FormattedDate
										date={featuredPost.data.pubDate}
									/>

									<span aria-hidden="true">
										•
									</span>

									<span>
										{featuredPost.data.readingTime}
									</span>

								</div>

							</div>

							<h2>
								{featuredPost.data.title}
							</h2>

							<p>
								{featuredPost.data.description}
							</p>

							<div class="read">
								Ler artigo
								<span aria-hidden="true">→</span>
							</div>

						</div>

					</a>

				</section>

			)
		}

		<section class="grid" id="articles-grid">

			{
				regularPosts.map((post) => (

					<a
						class="card searchable-post"
						href={`/blog/${post.id}/`}
						data-search={`
							${post.data.title}
							${post.data.description}
							${post.data.category}
							${post.data.tags.join(" ")}
						`}
					>

						<div class="card-image">

							{
								post.data.heroImage ? (

									<Image
										src={post.data.heroImage}
										width={900}
										height={500}
										alt={post.data.title}
									/>

								) : (

									<div class="image-placeholder">
										PagoMeia
									</div>

								)
							}

						</div>

						<div class="content">

							<div class="meta">

								<span class="category">
									{post.data.category}
								</span>

								<div class="date-info">

									<FormattedDate
										date={post.data.pubDate}
									/>

									<span aria-hidden="true">
										•
									</span>

									<span>
										{post.data.readingTime}
									</span>

								</div>

							</div>

							<h2>
								{post.data.title}
							</h2>

							<p>
								{post.data.description}
							</p>

							<div class="read">
								Ler artigo
								<span aria-hidden="true">→</span>
							</div>

						</div>

					</a>

				))
			}

		</section>

		<section class="no-results" id="no-results" hidden>

			<div class="no-results-icon">
				🔎
			</div>

			<h2>
				Nenhum artigo encontrado
			</h2>

			<p>
				Tente pesquisar usando outro título, assunto ou categoria.
			</p>

		</section>

	</main>

	<Footer />

	<script>

		const searchInput = document.querySelector("#article-search");
		const searchablePosts = Array.from(
			document.querySelectorAll(".searchable-post")
		);
		const noResults = document.querySelector("#no-results");
		const resultCount = document.querySelector("#result-count");

		const normalizeText = (text) => {
			return text
				.toLowerCase()
				.normalize("NFD")
				.replace(/[\u0300-\u036f]/g, "")
				.trim();
		};

		const updateResults = () => {

			if (!(searchInput instanceof HTMLInputElement)) {
				return;
			}

			const searchTerm = normalizeText(searchInput.value);
			let visiblePosts = 0;

			searchablePosts.forEach((post) => {

				if (!(post instanceof HTMLElement)) {
					return;
				}

				const searchableText = normalizeText(
					post.dataset.search ?? ""
				);

				const matchesSearch =
					searchTerm === "" ||
					searchableText.includes(searchTerm);

				post.hidden = !matchesSearch;

				if (matchesSearch) {
					visiblePosts += 1;
				}

			});

			if (noResults instanceof HTMLElement) {
				noResults.hidden = visiblePosts !== 0;
			}

			if (resultCount instanceof HTMLElement) {

				if (searchTerm === "") {

					resultCount.textContent =
						visiblePosts === 1
							? "1 artigo publicado"
							: `${visiblePosts} artigos publicados`;

				} else {

					resultCount.textContent =
						visiblePosts === 1
							? "1 artigo encontrado"
							: `${visiblePosts} artigos encontrados`;

				}

			}

		};

		searchInput?.addEventListener("input", updateResults);

	</script>

</body>

</html>

<style>

	.page {

		width: min(1500px, calc(100% - 64px));

		margin: auto;

		padding: 60px 0 90px;

	}

	.hero {

		max-width: 900px;

		margin: 0 auto 70px;

		text-align: center;

	}

	.hero-label {

		display: inline-block;

		padding: 8px 16px;

		border-radius: 999px;

		background: #efe7ff;

		color: #6d28d9;

		font-size: 12px;

		font-weight: 800;

		letter-spacing: .08em;

		text-transform: uppercase;

	}

	.hero h1 {

		margin: 24px 0 20px;

		font-size: clamp(52px, 7vw, 88px);

		line-height: .95;

		letter-spacing: -.05em;

	}

	.hero > p:not(.result-count) {

		max-width: 760px;

		margin: auto;

		color: #666;

		font-size: 20px;

		line-height: 1.8;

	}

	.search-wrapper {

		position: relative;

		max-width: 720px;

		margin: 38px auto 0;

	}

	.search-icon {

		position: absolute;

		top: 50%;

		left: 22px;

		width: 22px;

		height: 22px;

		transform: translateY(-50%);

		fill: none;

		stroke: #777;

		stroke-width: 2;

		stroke-linecap: round;

		pointer-events: none;

	}

	.search-wrapper input {

		width: 100%;

		height: 64px;

		padding: 0 24px 0 58px;

		border: 1px solid #e6dfef;

		border-radius: 18px;

		outline: none;

		background: #fff;

		color: #111;

		font: inherit;

		font-size: 16px;

		box-shadow: 0 14px 40px rgba(0, 0, 0, .05);

		transition: .2s;

	}

	.search-wrapper input::placeholder {

		color: #999;

	}

	.search-wrapper input:focus {

		border-color: #7c3aed;

		box-shadow:
			0 0 0 4px rgba(124, 58, 237, .1),
			0 18px 45px rgba(0, 0, 0, .07);

	}

	.result-count {

		margin: 14px 0 0;

		color: #999;

		font-size: 13px;

	}

	.featured-section {

		margin-bottom: 34px;

	}

	.featured-card {

		display: grid;

		grid-template-columns: minmax(0, 1.25fr) minmax(380px, .75fr);

		overflow: hidden;

		min-height: 490px;

		border: 1px solid #e8e1f0;

		border-radius: 28px;

		background: #fff;

		color: #111;

		text-decoration: none;

		box-shadow: 0 18px 50px rgba(0, 0, 0, .06);

		transition: .25s;

	}

	.featured-card:hover {

		transform: translateY(-7px);

		border-color: #7c3aed;

		box-shadow: 0 28px 70px rgba(0, 0, 0, .1);

	}

	.featured-image {

		position: relative;

		overflow: hidden;

		min-height: 490px;

		background: #17131f;

	}

	.featured-image img {

		width: 100%;

		height: 100%;

		object-fit: cover;

		display: block;

		transition: transform .5s;

	}

	.featured-card:hover .featured-image img {

		transform: scale(1.035);

	}

	.featured-badge {

		position: absolute;

		top: 22px;

		left: 22px;

		padding: 8px 13px;

		border-radius: 999px;

		background: #7c3aed;

		color: #fff;

		font-size: 11px;

		font-weight: 900;

		letter-spacing: .08em;

		box-shadow: 0 8px 25px rgba(0, 0, 0, .18);

	}

	.featured-content {

		display: flex;

		flex-direction: column;

		justify-content: center;

		padding: 50px;

	}

	.featured-meta,
	.meta {

		display: flex;

		justify-content: space-between;

		align-items: center;

		gap: 16px;

		margin-bottom: 20px;

		font-size: 12px;

		color: #888;

	}

	.category {

		display: inline-flex;

		align-items: center;

		padding: 6px 11px;

		border-radius: 999px;

		background: #efe7ff;

		color: #6d28d9;

		font-weight: 800;

	}

	.date-info {

		display: flex;

		align-items: center;

		justify-content: flex-end;

		gap: 7px;

		text-align: right;

	}

	.featured-content h2 {

		margin: 0;

		font-size: clamp(38px, 4vw, 58px);

		line-height: 1.02;

		letter-spacing: -.045em;

	}

	.featured-content p {

		margin: 24px 0 34px;

		color: #666;

		font-size: 17px;

		line-height: 1.8;

	}

	.grid {

		display: grid;

		grid-template-columns: repeat(2, minmax(0, 1fr));

		gap: 34px;

		align-items: stretch;

	}

	.card {

		display: flex;

		flex-direction: column;

		overflow: hidden;

		border: 1px solid #ece7f3;

		border-radius: 24px;

		background: #fff;

		text-decoration: none;

		color: #111;

		transition: .25s;

		box-shadow: 0 14px 40px rgba(0, 0, 0, .04);

	}

	.card:hover {

		transform: translateY(-8px);

		box-shadow: 0 24px 60px rgba(0, 0, 0, .08);

		border-color: #7c3aed;

	}

	.card-image {

		overflow: hidden;

		background: #17131f;

	}

	.card-image img {

		width: 100%;

		aspect-ratio: 16 / 9;

		object-fit: cover;

		display: block;

		transition: .35s;

	}

	.card:hover .card-image img {

		transform: scale(1.03);

	}

	.image-placeholder {

		display: flex;

		align-items: center;

		justify-content: center;

		width: 100%;

		height: 100%;

		min-height: 280px;

		background:
			radial-gradient(
				circle at 20% 20%,
				rgba(124, 58, 237, .8),
				transparent 40%
			),
			linear-gradient(
				135deg,
				#17131f,
				#2d1746
			);

		color: #fff;

		font-size: 30px;

		font-weight: 900;

		letter-spacing: -.04em;

	}

	.content {

		display: flex;

		flex: 1;

		flex-direction: column;

		padding: 24px;

	}

	.meta {

		margin-bottom: 18px;

	}

	.content h2 {

		margin: 0;

		font-size: 30px;

		line-height: 1.15;

		letter-spacing: -.03em;

	}

	.content p {

		flex: 1;

		margin: 18px 0 28px;

		color: #666;

		line-height: 1.8;

	}

	.read {

		display: inline-flex;

		align-items: center;

		gap: 8px;

		color: #6d28d9;

		font-weight: 800;

	}

	.read span {

		transition: transform .2s;

	}

	.card:hover .read span,
	.featured-card:hover .read span {

		transform: translateX(6px);

	}

	.searchable-post[hidden] {

		display: none;

	}

	.no-results {

		padding: 80px 20px;

		text-align: center;

	}

	.no-results[hidden] {

		display: none;

	}

	.no-results-icon {

		margin-bottom: 16px;

		font-size: 42px;

	}

	.no-results h2 {

		margin: 0;

		font-size: 32px;

		letter-spacing: -.03em;

	}

	.no-results p {

		margin: 14px 0 0;

		color: #777;

	}

	@media (max-width: 1100px) {

		.featured-card {

			grid-template-columns: 1fr;

		}

		.featured-image {

			min-height: 430px;

		}

		.featured-content {

			padding: 38px;

		}

	}

	@media (max-width: 1000px) {

		.grid {

			grid-template-columns: 1fr;

		}

	}

	@media (max-width: 700px) {

		.page {

			width: min(100% - 28px, 600px);

			padding: 36px 0 60px;

		}

		.hero {

			margin-bottom: 45px;

		}

		.hero h1 {

			font-size: 54px;

		}

		.hero > p:not(.result-count) {

			font-size: 17px;

		}

		.search-wrapper {

			margin-top: 28px;

		}

		.search-wrapper input {

			height: 58px;

			border-radius: 16px;

		}

		.featured-card {

			min-height: 0;

			border-radius: 22px;

		}

		.featured-image {

			min-height: 250px;

		}

		.featured-content {

			padding: 24px 20px 28px;

		}

		.featured-content h2 {

			font-size: 34px;

		}

		.featured-content p {

			margin: 18px 0 26px;

			font-size: 16px;

		}

		.featured-meta,
		.meta {

			align-items: flex-start;

			flex-direction: column;

			gap: 10px;

		}

		.date-info {

			justify-content: flex-start;

			text-align: left;

		}

		.content {

			padding: 20px;

		}

		.content h2 {

			font-size: 24px;

		}

	}

</style>