---
import { Image } from "astro:assets";
import logo from "../assets/logo.png";

import { SITE_TITLE } from "../consts";
import HeaderLink from "./HeaderLink.astro";
---

<header>
	<div class="gradient"></div>

	<div class="container">
		<a href="/" class="brand">
			<Image
				src={logo}
				alt="Logo do PagoMeia"
				class="logo"
				width={68}
				height={68}
			/>

			<div class="brand-info">
				<h2>{SITE_TITLE} <span></span></h2>
				<p>A sua meia-entrada para a cultura pop.</p>
			</div>
		</a>

		<nav aria-label="Navegação principal">
			<HeaderLink href="/">Início</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<a href="/#jogos">Jogos</a>

			<a
				class="youtube"
				href="https://youtube.com/@pagomeia"
				target="_blank"
				rel="noopener noreferrer"
			>
				<span class="play">▶</span>
				<span>Canal no YouTube</span>
			</a>
		</nav>
	</div>
</header>

<style>
	.gradient {
		height: 4px;
		background: linear-gradient(
			90deg,
			#7c3aed 0%,
			#a855f7 36%,
			#ec4899 70%,
			#ef4444 100%
		);
	}

	header {
		position: sticky;
		top: 0;
		z-index: 999;
		border-bottom: 1px solid rgba(124, 58, 237, 0.1);
		background: rgba(255, 255, 255, 0.94);
		box-shadow: 0 8px 30px rgba(31, 20, 45, 0.04);
		backdrop-filter: blur(18px);
	}

	.container {
		width: min(1500px, calc(100% - 56px));
		min-height: 92px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 36px;
	}

	.brand {
		display: flex;
		align-items: center;
		gap: 17px;
		min-width: 0;
		color: inherit;
		text-decoration: none;
	}

	.logo {
		width: 68px;
		height: 68px;
		flex-shrink: 0;
		border: 3px solid rgba(124, 58, 237, 0.12);
		border-radius: 50%;
		object-fit: cover;
		box-shadow: 0 10px 28px rgba(124, 58, 237, 0.2);
		transition: transform 0.22s ease;
	}

	.brand:hover .logo {
		transform: rotate(-3deg) scale(1.04);
	}

	.brand-info {
		display: flex;
		flex-direction: column;
		min-width: 0;
	}

	.brand-info h2 {
		margin: 0;
		color: #17111f;
		font-size: 24px;
		font-weight: 850;
		line-height: 1.05;
		letter-spacing: -0.03em;
		white-space: nowrap;
	}

	.brand-info h2 span {
		color: #6d28d9;
		font-weight: 750;
	}

	.brand-info p {
		margin: 7px 0 0;
		color: #77727e;
		font-size: 13px;
		line-height: 1.2;
	}

	nav {
		display: flex;
		align-items: center;
		gap: 10px;
	}

	nav :global(a) {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 44px;
		padding: 0 14px;
		border-radius: 10px;
		color: #26212b;
		text-decoration: none;
		font-size: 14px;
		font-weight: 750;
		transition:
			color 0.2s ease,
			background 0.2s ease,
			transform 0.2s ease;
	}

	nav :global(a:hover) {
		background: #f5efff;
		color: #6d28d9;
	}

	.youtube {
		gap: 9px;
		margin-left: 8px;
		padding: 0 18px !important;
		background: #ff0000 !important;
		color: #ffffff !important;
		box-shadow: 0 10px 24px rgba(255, 0, 0, 0.18);
	}

	.youtube:hover {
		background: #e60000 !important;
		color: #ffffff !important;
		transform: translateY(-2px);
		box-shadow: 0 14px 28px rgba(255, 0, 0, 0.25);
	}

	.play {
		display: inline-grid;
		width: 24px;
		height: 24px;
		place-items: center;
		border-radius: 50%;
		background: rgba(255, 255, 255, 0.18);
		font-size: 11px;
	}

	@media (max-width: 980px) {
		.container {
			width: min(100% - 32px, 900px);
			min-height: 80px;
		}

		.logo {
			width: 56px;
			height: 56px;
		}

		.brand-info h2 {
			font-size: 20px;
		}

		.brand-info p {
			display: none;
		}

		nav {
			gap: 4px;
		}

		nav :global(a) {
			padding: 0 10px;
		}
	}

	@media (max-width: 720px) {
		.container {
			width: min(100% - 24px, 600px);
			min-height: 72px;
		}

		.logo {
			width: 48px;
			height: 48px;
		}

		.brand-info h2 {
			font-size: 18px;
		}

		.brand-info h2 span {
			display: none;
		}

		nav :global(a:not(.youtube)) {
			display: none;
		}

		.youtube {
			margin-left: 0;
			padding: 0 14px !important;
		}

		.youtube span:last-child {
			display: none;
		}
	}
</style>