---
interface Props {
  id: string;
}

const { id } = Astro.props;
---

<div class="youtube">
  <iframe
    src={`https://www.youtube.com/embed/${id}`}
    title="YouTube video player"
    loading="lazy"
    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
    allowfullscreen>
  </iframe>
</div>

<style>
.youtube {
  position: relative;
  width: 100%;
  padding-bottom: 56.25%;
  margin: 2rem 0;
}

.youtube iframe {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  border: 0;
  border-radius: 12px;
}
</style>