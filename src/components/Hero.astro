---
import { Image } from "astro:assets";
import heroImage from "../assets/theboys.jpg";
---

<section class="hero">
	<div class="content">
		<span class="eyebrow">
			Cinema • Séries • Games • Reacts
		</span>

		<h1>PagoMeia</h1>

		<h2>
			A sua meia-entrada para a cultura pop.
		</h2>

		<p>
			Críticas, reacts, listas, curiosidades e jogos para quem ama
			entretenimento. Tudo com a personalidade do PagoMeia.
		</p>

		<div class="actions">
			<a
				class="youtube"
				href="https://youtube.com/@pagomeia"
				target="_blank"
				rel="noopener noreferrer"
			>
				▶ Conheça o canal
			</a>

			<a class="games" href="#jogos">
				🎮 Explorar jogos
			</a>
		</div>

		<div class="highlights">
			<div>
				<strong>Conteúdo</strong>
				<span>Críticas, reacts e listas</span>
			</div>

			<div>
				<strong>Jogos</strong>
				<span>Experiências para jogar com a galera</span>
			</div>

			<div>
				<strong>Comunidade</strong>
				<span>Cultura pop sem frescura</span>
			</div>
		</div>
	</div>

	<div class="visual">
		<a
			class="video-card"
			href="https://youtube.com/@pagomeia"
			target="_blank"
			rel="noopener noreferrer"
		>
			<Image
				src={heroImage}
				alt="Conteúdo em destaque do canal PagoMeia"
				width={1280}
				height={720}
				loading="eager"
			/>

			<div class="video-overlay">
				<span class="play">▶</span>

				<div>
					<small>Assista no YouTube</small>
					<strong>Críticas, reacts e muita farra</strong>
				</div>
			</div>
		</a>
	</div>
</section>

<style>
	.hero {
		display: grid;
		grid-template-columns: minmax(0, 1.05fr) minmax(380px, 0.95fr);
		gap: 72px;
		align-items: center;
		padding: 72px 0 58px;
	}

	.eyebrow {
		display: inline-flex;
		padding: 9px 15px;
		border-radius: 999px;
		background: #efe7ff;
		color: #6d28d9;
		font-size: 13px;
		font-weight: 800;
		letter-spacing: 0.04em;
	}

	h1 {
		margin: 24px 0 0;
		font-size: clamp(68px, 8vw, 116px);
		line-height: 0.86;
		letter-spacing: -0.07em;
	}

	h2 {
		max-width: 720px;
		margin: 28px 0 0;
		font-size: clamp(32px, 4vw, 54px);
		line-height: 1.06;
		letter-spacing: -0.04em;
	}

	p {
		max-width: 720px;
		margin: 28px 0 0;
		color: #5f636b;
		font-size: 18px;
		line-height: 1.8;
	}

	.actions {
		display: flex;
		flex-wrap: wrap;
		gap: 14px;
		margin-top: 34px;
	}

	.actions a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 15px 22px;
		border-radius: 13px;
		text-decoration: none;
		font-size: 15px;
		font-weight: 800;
		transition:
			transform 0.2s ease,
			box-shadow 0.2s ease;
	}

	.actions a:hover {
		transform: translateY(-3px);
	}

	.youtube {
		background: #ff0000;
		color: #ffffff;
		box-shadow: 0 14px 30px rgba(255, 0, 0, 0.2);
	}

	.games {
		background: #17111f;
		color: #ffffff;
		box-shadow: 0 14px 30px rgba(23, 17, 31, 0.14);
	}

	.highlights {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 14px;
		margin-top: 42px;
	}

	.highlights div {
		padding: 18px;
		border: 1px solid #ece7f3;
		border-radius: 16px;
		background: #ffffff;
	}

	.highlights strong,
	.highlights span {
		display: block;
	}

	.highlights strong {
		font-size: 15px;
	}

	.highlights span {
		margin-top: 5px;
		color: #77727e;
		font-size: 12px;
		line-height: 1.45;
	}

	.visual {
		min-width: 0;
	}

	.video-card {
		position: relative;
		display: block;
		overflow: hidden;
		border: 3px solid transparent;
		border-radius: 28px;
		background:
			linear-gradient(#ffffff, #ffffff) padding-box,
			linear-gradient(135deg, #7c3aed, #ec4899, #ff0000) border-box;
		box-shadow: 0 34px 80px rgba(40, 20, 68, 0.18);
		text-decoration: none;
	}

	.video-card :global(img) {
		display: block;
		width: 100%;
		height: auto;
		aspect-ratio: 16 / 9;
		object-fit: cover;
		transition: transform 0.35s ease;
	}

	.video-card:hover :global(img) {
		transform: scale(1.035);
	}

	.video-overlay {
		position: absolute;
		right: 18px;
		bottom: 18px;
		left: 18px;
		display: flex;
		align-items: center;
		gap: 14px;
		padding: 16px;
		border-radius: 16px;
		background: rgba(20, 14, 28, 0.88);
		color: #ffffff;
		backdrop-filter: blur(12px);
	}

	.play {
		display: grid;
		width: 42px;
		height: 42px;
		flex-shrink: 0;
		place-items: center;
		border-radius: 50%;
		background: #ff0000;
	}

	.video-overlay small,
	.video-overlay strong {
		display: block;
	}

	.video-overlay small {
		color: #d9c5ff;
		font-size: 11px;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.video-overlay strong {
		margin-top: 3px;
		font-size: 16px;
	}

	@media (max-width: 1050px) {
		.hero {
			grid-template-columns: 1fr;
			gap: 48px;
		}

		.visual {
			max-width: 820px;
		}
	}

	@media (max-width: 700px) {
		.hero {
			padding-top: 46px;
		}

		.highlights {
			grid-template-columns: 1fr;
		}
	}
</style>