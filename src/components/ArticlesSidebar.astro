---
const { posts = [] } = Astro.props;

const getImageSrc = (image) => {
	if (!image) return `${base}logo.png`;
	return typeof image === "string" ? image : image.src;
};
---
const base = import.meta.env.BASE_URL;
<aside class="sidebar">
	<div class="heading">
		<div>
			<span>ARTIGOS</span>
			<h2>Conteúdos recentes</h2>
		</div>

		<a href="/blog">Ver todos →</a>
	</div>

	<div class="articles">
		{
			posts.length > 0 ? (
				posts.map((post) => (
					<a class="article" href={`/blog/${post.id}/`}>
						<img
							src={getImageSrc(post.data.heroImage)}
							alt={post.data.title}
							loading="lazy"
						/>

						<div class="article-content">
							<span class="category">PagoMeia</span>

							<h3>{post.data.title}</h3>

							<p>{post.data.description}</p>

							<small>
								{post.data.pubDate.toLocaleDateString("pt-BR", {
									day: "2-digit",
									month: "short",
									year: "numeric",
								})}
							</small>
						</div>
					</a>
				))
			) : (
				<div class="empty">
					<img src={`${base}logo.png`} alt="Logo PagoMeia" />

					<h3>Os artigos aparecem aqui</h3>

					<p>
						Crie um arquivo em
						<code>src/content/blog</code> para publicar o primeiro conteúdo.
					</p>
				</div>
			)
		}
	</div>

	<a class="all-posts" href="/blog">
		Acessar todos os artigos →
	</a>
</aside>

<style>
	.sidebar {
		padding: 30px;
		border: 1px solid #ece7f3;
		border-radius: 24px;
		background: #ffffff;
		box-shadow: 0 24px 60px rgba(37, 22, 58, 0.07);
	}

	.heading {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 20px;
		margin-bottom: 26px;
	}

	.heading span {
		color: #7c3aed;
		font-size: 12px;
		font-weight: 800;
		letter-spacing: 0.12em;
	}

	.heading h2 {
		margin: 6px 0 0;
		font-size: 28px;
		line-height: 1.1;
		letter-spacing: -0.03em;
	}

	.heading a {
		flex-shrink: 0;
		color: #111827;
		text-decoration: none;
		font-size: 13px;
		font-weight: 800;
	}

	.articles {
		display: flex;
		flex-direction: column;
		gap: 18px;
	}

	.article {
		display: grid;
		grid-template-columns: 130px minmax(0, 1fr);
		gap: 16px;
		padding: 12px;
		border-radius: 16px;
		color: #111827;
		text-decoration: none;
		transition:
			background 0.2s ease,
			transform 0.2s ease;
	}

	.article:hover {
		background: #faf7ff;
		transform: translateX(4px);
	}

	.article img {
		width: 130px;
		height: 94px;
		border-radius: 12px;
		background: #eee8f7;
		object-fit: cover;
	}

	.article-content {
		min-width: 0;
	}

	.category {
		display: inline-flex;
		padding: 4px 8px;
		border-radius: 999px;
		background: #efe7ff;
		color: #6d28d9;
		font-size: 10px;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.06em;
	}

	.article h3 {
		display: -webkit-box;
		margin: 8px 0 5px;
		overflow: hidden;
		font-size: 16px;
		line-height: 1.3;
		-webkit-box-orient: vertical;
		-webkit-line-clamp: 2;
	}

	.article p {
		display: -webkit-box;
		margin: 0;
		overflow: hidden;
		color: #6b7280;
		font-size: 12px;
		line-height: 1.45;
		-webkit-box-orient: vertical;
		-webkit-line-clamp: 2;
	}

	.article small {
		display: block;
		margin-top: 7px;
		color: #9ca3af;
		font-size: 11px;
	}

	.all-posts {
		display: flex;
		justify-content: center;
		margin-top: 24px;
		padding: 13px 16px;
		border-radius: 12px;
		background: #17111f;
		color: #ffffff;
		text-decoration: none;
		font-size: 14px;
		font-weight: 800;
		transition:
			transform 0.2s ease,
			background 0.2s ease;
	}

	.all-posts:hover {
		background: #7c3aed;
		color: #ffffff;
		transform: translateY(-2px);
	}

	.empty {
		padding: 34px 22px;
		border: 1px dashed #d8cce9;
		border-radius: 18px;
		text-align: center;
	}

	.empty img {
		width: 72px;
		height: 72px;
		border-radius: 50%;
		object-fit: cover;
	}

	.empty h3 {
		margin: 16px 0 8px;
		font-size: 19px;
	}

	.empty p {
		margin: 0;
		color: #6b7280;
		font-size: 13px;
		line-height: 1.6;
	}

	.empty code {
		font-size: 12px;
	}

	@media (max-width: 520px) {
		.sidebar {
			padding: 22px;
		}

		.heading {
			align-items: flex-start;
			flex-direction: column;
		}

		.article {
			grid-template-columns: 105px minmax(0, 1fr);
		}

		.article img {
			width: 105px;
			height: 84px;
		}

		.article p {
			display: none;
		}
	}
</style>