---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";

import logo from "../assets/logo.png";

type Props = CollectionEntry<"blog">["data"];

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	author,
	category,
	tags,
} = Astro.props;

const base = import.meta.env.BASE_URL;

const content = await Astro.slots.render("default");

const wordCount = content
	.replace(/<[^>]*>/g, " ")
	.trim()
	.split(/\s+/)
	.filter(Boolean).length;

const readingTime = Math.max(1, Math.ceil(wordCount / 220));
---

<!doctype html>

<html lang="pt-BR">
	<head>
		<BaseHead
			title={`${title} | PagoMeia`}
			description={description}
			image={heroImage}
		/>
	</head>

	<body>
		<Header />

		<main>
			<article>
				<header class="article-header">
					<div class="article-header-inner">
						<a class="back-link" href={`${base}blog/`}>
							← Voltar para o blog
						</a>

						<span class="category">
							{category}
						</span>

						<h1>{title}</h1>

						<p class="description">
							{description}
						</p>

						<div class="meta">
							<div class="author">
								<Image
									src={logo}
									alt="Logo do PagoMeia"
									width={44}
									height={44}
								/>

								<div>
									<span>Escrito por</span>
									<strong>{author}</strong>
								</div>
							</div>

							<div class="article-details">
								<span>
									📅 <FormattedDate date={pubDate} />
								</span>

								<span>
									⏱ {readingTime} min de leitura
								</span>

								{
									updatedDate && (
										<span>
											Atualizado em <FormattedDate date={updatedDate} />
										</span>
									)
								}
							</div>
						</div>
					</div>
				</header>

				{
					heroImage && (
						<div class="hero-image">
							<img
								src={heroImage}
								alt={title}
								width={1400}
								height={788}
								loading="eager"
							/>
						</div>
					)
				}

				<div class="content-wrapper">
					<div class="prose">
						<Fragment set:html={content} />
					</div>

					{
						tags.length > 0 && (
							<section class="tags">
								<span class="tags-title">Assuntos deste artigo</span>

								<div class="tag-list">
									{tags.map((tag) => <span>#{tag}</span>)}
								</div>
							</section>
						)
					}

					<section class="channel-cta">
						<div class="channel-brand">
							<Image
								src={logo}
								alt="Logo do PagoMeia"
								width={78}
								height={78}
							/>

							<div>
								<span>Continua a conversa</span>

								<h2>
									Esse assunto provavelmente renderia uma discussão no canal.
								</h2>

								<p>
									Conheça os vídeos, reacts, críticas e outras ideias
									questionáveis do PagoMeia.
								</p>
							</div>
						</div>

						<a
							href="https://youtube.com/@pagomeia"
							target="_blank"
							rel="noopener noreferrer"
						>
							▶ Conheça o canal
						</a>
					</section>

					<nav class="article-navigation">
						<a href={`${base}blog/`}>
							← Ver todos os artigos
						</a>

						<a href={`${base}#jogos`}>
							Explorar os jogos →
						</a>
					</nav>
				</div>
			</article>
		</main>

		<Footer />
	</body>
</html>

<style>
	main {
		width: min(1400px, calc(100% - 56px));
		margin: 0 auto;
		padding-top: 54px;
	}

	.article-header {
		padding: 42px 0 48px;
	}

	.article-header-inner {
		max-width: 1050px;
		margin: 0 auto;
		text-align: center;
	}

	.back-link {
		display: inline-flex;
		margin-bottom: 34px;
		color: #6d28d9;
		text-decoration: none;
		font-size: 14px;
		font-weight: 800;
		transition: transform 0.2s ease;
	}

	.back-link:hover {
		transform: translateX(-4px);
	}

	.category {
		display: table;
		margin: 0 auto;
		padding: 8px 14px;
		border-radius: 999px;
		background: #efe7ff;
		color: #6d28d9;
		font-size: 12px;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	h1 {
		max-width: 1050px;
		margin: 24px auto 0;
		color: #11131a;
		font-size: clamp(48px, 7vw, 92px);
		line-height: 0.98;
		letter-spacing: -0.055em;
	}

	.description {
		max-width: 820px;
		margin: 28px auto 0;
		color: #65606a;
		font-size: 20px;
		line-height: 1.7;
	}

	.meta {
		display: flex;
		align-items: center;
		justify-content: center;
		flex-wrap: wrap;
		gap: 24px 38px;
		margin-top: 34px;
	}

	.author {
		display: flex;
		align-items: center;
		gap: 12px;
		text-align: left;
	}

	.author :global(img) {
		width: 44px;
		height: 44px;
		border-radius: 50%;
		object-fit: cover;
		box-shadow: 0 8px 20px rgba(124, 58, 237, 0.18);
	}

	.author span,
	.author strong {
		display: block;
	}

	.author span {
		color: #97919c;
		font-size: 11px;
	}

	.author strong {
		margin-top: 2px;
		color: #28232c;
		font-size: 14px;
	}

	.article-details {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 10px 20px;
		color: #817a86;
		font-size: 13px;
	}

	.hero-image {
		max-width: 1220px;
		margin: 0 auto;
		overflow: hidden;
		border-radius: 28px;
		box-shadow: 0 30px 70px rgba(37, 22, 58, 0.13);
	}

	.hero-image :global(img) {
		display: block;
		width: 100%;
		height: auto;
		aspect-ratio: 16 / 9;
		object-fit: cover;
	}

	.content-wrapper {
		width: min(780px, 100%);
		margin: 0 auto;
		padding: 70px 0 0;
	}

	.prose {
		color: #302b34;
		font-size: 19px;
		line-height: 1.9;
	}

	.prose :global(h1) {
		display: none;
	}

	.prose :global(h2) {
		margin: 58px 0 20px;
		color: #17131b;
		font-size: 38px;
		line-height: 1.12;
		letter-spacing: -0.035em;
	}

	.prose :global(h3) {
		margin: 42px 0 16px;
		color: #17131b;
		font-size: 28px;
		line-height: 1.2;
		letter-spacing: -0.025em;
	}

	.prose :global(p) {
		margin: 0 0 27px;
	}

	.prose :global(strong) {
		color: #18141c;
	}

	.prose :global(a) {
		color: #6d28d9;
		font-weight: 700;
	}

	.prose :global(ul),
	.prose :global(ol) {
		margin: 0 0 30px;
		padding-left: 26px;
	}

	.prose :global(li) {
		margin-bottom: 11px;
		padding-left: 5px;
	}

	.prose :global(blockquote) {
		margin: 40px 0;
		padding: 25px 28px;
		border-left: 4px solid #7c3aed;
		border-radius: 0 16px 16px 0;
		background: #faf7ff;
		color: #514a57;
		font-size: 21px;
		line-height: 1.7;
	}

	.prose :global(img) {
		display: block;
		width: 100%;
		margin: 38px 0;
		border-radius: 20px;
	}

	.prose :global(hr) {
		margin: 50px 0;
		border: 0;
		border-top: 1px solid #ece7f3;
	}

	.tags {
		margin-top: 60px;
		padding-top: 30px;
		border-top: 1px solid #ece7f3;
	}

	.tags-title {
		display: block;
		margin-bottom: 14px;
		color: #837c88;
		font-size: 12px;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.tag-list {
		display: flex;
		flex-wrap: wrap;
		gap: 9px;
	}

	.tag-list span {
		padding: 8px 12px;
		border-radius: 999px;
		background: #f3edff;
		color: #6d28d9;
		font-size: 13px;
		font-weight: 700;
	}

	.channel-cta {
		margin-top: 70px;
		padding: 34px;
		border-radius: 24px;
		background:
			radial-gradient(
				circle at top right,
				rgba(192, 132, 252, 0.25),
				transparent 38%
			),
			#17111f;
		color: #ffffff;
	}

	.channel-brand {
		display: flex;
		align-items: flex-start;
		gap: 22px;
	}

	.channel-brand :global(img) {
		width: 78px;
		height: 78px;
		flex-shrink: 0;
		border: 2px solid rgba(255, 255, 255, 0.14);
		border-radius: 50%;
		object-fit: cover;
	}

	.channel-brand span {
		color: #c7a5ff;
		font-size: 11px;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.09em;
	}

	.channel-brand h2 {
		margin: 8px 0 0;
		color: #ffffff;
		font-size: 29px;
		line-height: 1.14;
		letter-spacing: -0.035em;
	}

	.channel-brand p {
		margin: 13px 0 0;
		color: rgba(255, 255, 255, 0.66);
		font-size: 14px;
		line-height: 1.7;
	}

	.channel-cta > a {
		display: inline-flex;
		margin-top: 25px;
		padding: 14px 19px;
		border-radius: 11px;
		background: #ff0000;
		color: #ffffff;
		text-decoration: none;
		font-size: 14px;
		font-weight: 800;
		transition:
			transform 0.2s ease,
			box-shadow 0.2s ease;
	}

	.channel-cta > a:hover {
		transform: translateY(-2px);
		box-shadow: 0 12px 25px rgba(255, 0, 0, 0.24);
	}

	.article-navigation {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 20px;
		margin-top: 30px;
		padding-top: 26px;
		border-top: 1px solid #ece7f3;
	}

	.article-navigation a {
		color: #6d28d9;
		text-decoration: none;
		font-size: 14px;
		font-weight: 800;
	}

	@media (max-width: 700px) {
		main {
			width: min(100% - 28px, 620px);
			padding-top: 26px;
		}

		.article-header {
			padding: 30px 0 36px;
		}

		.back-link {
			margin-bottom: 26px;
		}

		.description {
			font-size: 17px;
		}

		.meta {
			align-items: flex-start;
			flex-direction: column;
		}

		.article-details {
			justify-content: flex-start;
		}

		.hero-image {
			border-radius: 18px;
		}

		.content-wrapper {
			padding-top: 45px;
		}

		.prose {
			font-size: 17px;
		}

		.prose :global(h2) {
			margin-top: 46px;
			font-size: 31px;
		}

		.prose :global(h3) {
			font-size: 25px;
		}

		.channel-cta {
			padding: 27px 22px;
		}

		.channel-brand {
			flex-direction: column;
		}

		.channel-brand h2 {
			font-size: 25px;
		}

		.article-navigation {
			align-items: flex-start;
			flex-direction: column;
		}
	}
</style>