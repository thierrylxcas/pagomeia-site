		transform: translateY(-5px);
		border-color: #d8c7ee;
		box-shadow: 0 20px 42px rgba(39, 22, 56, 0.11);
	}

	.card-content {
		display: flex;
		flex: 1;
		flex-direction: column;
		padding: 21px;
	}

