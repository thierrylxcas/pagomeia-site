		margin: 0;
		font-size: 21px;
		line-height: 1.18;
	}

	.related-card p {
		display: -webkit-box;
		margin: 11px 0 0;
		overflow: hidden;
		color: #746d79;
		font-size: 13px;
		line-height: 1.6;
		-webkit-box-orient: vertical;
		-webkit-line-clamp: 3;
	}

	.related-card .related-link {
		margin-top: auto;
		padding-top: 18px;
	}

	.channel-cta {
		margin-top: 70px;
		padding: 34px;
		border-radius: 24px;
		background:
			radial-gradient(
				circle at top right,
				rgba(192, 132, 252, 0.25),
				transparent 38%
			),
			#17111f;
		color: #ffffff;
	}

	.channel-brand {
		display: flex;
		align-items: flex-start;
		gap: 22px;
	}

	.channel-brand :global(img) {
		width: 78px;
		height: 78px;
		flex-shrink: 0;
		border: 2px solid rgba(255, 255, 255, 0.14);
		border-radius: 50%;
		object-fit: cover;
	}

	.channel-brand span {
		color: #c7a5ff;
		font-size: 11px;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.09em;
	}

	.channel-brand h2 {
		margin: 8px 0 0;
		color: #ffffff;
		font-size: 29px;
		line-height: 1.14;
		letter-spacing: -0.035em;
	}

	.channel-brand p {
		margin: 13px 0 0;
		color: rgba(255, 255, 255, 0.66);
		font-size: 14px;
		line-height: 1.7;
	}

	.channel-cta > a {
		display: inline-flex;
		margin-top: 25px;
		padding: 14px 19px;
		border-radius: 11px;
		background: #ff0000;
		color: #ffffff;
		text-decoration: none;
		font-size: 14px;
		font-weight: 800;
		transition:
			transform 0.2s ease,
			box-shadow 0.2s ease;
	}

	.channel-cta > a:hover {
		transform: translateY(-2px);
		box-shadow: 0 12px 25px rgba(255, 0, 0, 0.24);
	}

	.article-navigation {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 20px;
		margin-top: 30px;
		padding-top: 26px;
		border-top: 1px solid #ece7f3;
	}

	.article-navigation a {
		color: #6d28d9;
		text-decoration: none;
		font-size: 14px;
		font-weight: 800;
	}

