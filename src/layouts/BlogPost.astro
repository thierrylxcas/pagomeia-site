---
import { Image } from "astro:assets";
import {
	getCollection,
	type CollectionEntry,
} from "astro:content";

import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";

import logo from "../assets/logo.png";

type Props = CollectionEntry<"blog">["data"];

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	author,
	category,
	tags,
	youtube,
} = Astro.props;

let videoId = "";

if (youtube) {
	const match = youtube.match(
		/(?:youtube\.com\/watch\?v=|youtube\.com\/shorts\/|youtu\.be\/)([^&?/]+)/,
	);

	videoId = match?.[1] ?? youtube;
}

const base = import.meta.env.BASE_URL;

const content = await Astro.slots.render("default");

const wordCount = content
	.replace(/<[^>]*>/g, " ")
	.trim()
	.split(/\s+/)
	.filter(Boolean).length;

const readingTime = Math.max(1, Math.ceil(wordCount / 220));

/*
 * ARTIGOS RECOMENDADOS
 *
 * 1. Remove o artigo atual.
 * 2. Ordena pelos mais recentes.
 * 3. Seleciona primeiro artigos de categorias diferentes.
 * 4. Completa até 3 recomendações caso não existam 3 categorias.
 */

const allPosts = (await getCollection("blog"))
	.filter((post) => post.data.pubDate <= new Date())
	.filter((post) => post.data.title !== title)
	.sort(
		(a, b) =>
			b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
	);

const relatedPosts: CollectionEntry<"blog">[] = [];
const selectedCategories = new Set<string>();

for (const post of allPosts) {
	const postCategory = post.data.category?.trim().toLowerCase();

	if (
		postCategory &&
		!selectedCategories.has(postCategory) &&
		relatedPosts.length < 3
	) {
		relatedPosts.push(post);
		selectedCategories.add(postCategory);
	}
}

if (relatedPosts.length < 3) {
	const selectedIds = new Set(relatedPosts.map((post) => post.id));

	for (const post of allPosts) {
		if (
			!selectedIds.has(post.id) &&
			relatedPosts.length < 3
		) {
			relatedPosts.push(post);
			selectedIds.add(post.id);
		}
	}
}

const featuredPost = relatedPosts[0];
const secondaryPosts = relatedPosts.slice(1, 3);

const getPostSlug = (postId: string) =>
	postId.replace(/\.(md|mdx)$/i, "");

const getPostUrl = (postId: string) =>
	`${base}blog/${getPostSlug(postId)}/`;
---

<!doctype html>

<html lang="pt-BR">
	<head>
		<BaseHead
			title={`${title} | PagoMeia`}
			description={description}
			image={heroImage}
		/>
	</head>

	<body>
		<Header />

		<main>
			<article>
				<header class="article-header">
					<div class="article-header-inner">
						<a class="back-link" href={`${base}blog/`}>
							← Voltar para o blog
						</a>

						<span class="category">
							{category}
						</span>

						<h1>{title}</h1>

						<p class="description">
							{description}
						</p>

						<div class="meta">
							<div class="author">
								<Image
									src={logo}
									alt="Logo do PagoMeia"
									width={44}
									height={44}
								/>

								<div>
									<span>Escrito por</span>
									<strong>{author}</strong>
								</div>
							</div>

							<div class="article-details">
								<span>
									📅 <FormattedDate date={pubDate} />
								</span>

								<span>
									⏱ {readingTime} min de leitura
								</span>

								{
									updatedDate && (
										<span>
											Atualizado em{" "}
											<FormattedDate date={updatedDate} />
										</span>
									)
								}
							</div>
						</div>
					</div>
				</header>

				{
					heroImage && (
						<div class="hero-image">
							<img
								src={heroImage}
								alt={title}
								width={1400}
								height={788}
								loading="eager"
							/>
						</div>
					)
				}

				<div class="content-wrapper">
					<div class="prose">
						<Fragment set:html={content} />
					</div>

					{
						videoId && (
							<div class="youtube-video">
								<iframe
									src={`https://www.youtube.com/embed/${videoId}`}
									title={title}
									loading="lazy"
									allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
									allowfullscreen
								/>
							</div>
						)
					}

					{
						tags.length > 0 && (
							<section class="tags">
								<span class="tags-title">
									Assuntos deste artigo
								</span>

								<div class="tag-list">
									{
										tags.map((tag) => (
											<span>#{tag}</span>
										))
									}
								</div>
							</section>
						)
					}

					{
						featuredPost && (
							<section
								class="related-posts"
								aria-labelledby="related-title"
							>
								<div class="related-heading">
									<span class="related-eyebrow">
										Novos artigos do PagoMeia
									</span>

									<h2 id="related-title">
										🎬 Continue explorando
									</h2>

									<p>
										Filmes, séries, terror, games e outros
										assuntos da cultura pop.
									</p>
								</div>

								<a
									class="related-featured"
									href={getPostUrl(featuredPost.id)}
									aria-label={`Ler artigo: ${featuredPost.data.title}`}
								>
									<div class="related-image">
										{
											featuredPost.data.heroImage ? (
												<img
													src={
														featuredPost.data
															.heroImage
													}
													alt=""
													loading="lazy"
												/>
											) : (
												<div class="image-placeholder">
													🎬
												</div>
											)
										}
									</div>

									<div class="featured-content">
										<span class="related-category">
											{featuredPost.data.category}
										</span>

										<h3>
											{featuredPost.data.title}
										</h3>

										<p>
											{
												featuredPost.data
													.description
											}
										</p>

										<span class="related-link">
											🍿 Continuar lendo
											<span aria-hidden="true">→</span>
										</span>
									</div>
								</a>

								{
									secondaryPosts.length > 0 && (
										<div class="related-grid">
											{
												secondaryPosts.map(
													(post) => (
														<a
															class="related-card"
															href={getPostUrl(
																post.id,
															)}
															aria-label={`Ler artigo: ${post.data.title}`}
														>
															<div class="related-image">
																{
																	post.data
																		.heroImage ? (
																		<img
																			src={
																				post
																					.data
																					.heroImage
																			}
																			alt=""
																			loading="lazy"
																		/>
																	) : (
																		<div class="image-placeholder">
																			🎟
																		</div>
																	)
																}
															</div>

															<div class="card-content">
																<span class="related-category">
																	{
																		post
																			.data
																			.category
																	}
																</span>

																<h3>
																	{
																		post
																			.data
																			.title
																	}
																</h3>

																<p>
																	{
																		post
																			.data
																			.description
																	}
																</p>

																<span class="related-link">
																	Descobrir
																	<span aria-hidden="true">
																		→
																	</span>
																</span>
															</div>
														</a>
													),
												)
											}
										</div>
									)
								}
							</section>
						)
					}

					<section class="channel-cta">
						<div class="channel-brand">
							<Image
								src={logo}
								alt="Logo do PagoMeia"
								width={78}
								height={78}
							/>

							<div>
								<span>Continua a conversa</span>

								<h2>
									Esse assunto provavelmente renderia uma
									discussão no canal.
								</h2>

								<p>
									Conheça os vídeos, reacts, críticas e outras
									ideias questionáveis do PagoMeia.
								</p>
							</div>
						</div>

						<a
							href="https://youtube.com/@pagomeia"
							target="_blank"
							rel="noopener noreferrer"
						>
							▶ Conheça o canal
						</a>
					</section>

					<nav class="article-navigation">
						<a href={`${base}blog/`}>
							← Ver todos os artigos
						</a>

						<a href={`${base}#jogos`}>
							Explorar os jogos →
						</a>
					</nav>
				</div>
			</article>
		</main>

		<Footer />
	</body>
</html>

<style>
	main {
		width: min(1400px, calc(100% - 56px));
		margin: 0 auto;
		padding-top: 54px;
	}

	.article-header {
		padding: 42px 0 48px;
	}

	.article-header-inner {
		max-width: 1050px;
		margin: 0 auto;
		text-align: center;
	}

	.back-link {
		display: inline-flex;
		margin-bottom: 34px;
		color: #6d28d9;
		text-decoration: none;
		font-size: 14px;
		font-weight: 800;
		transition: transform 0.2s ease;
	}

	.back-link:hover {
		transform: translateX(-4px);
	}

	.category {
		display: table;
		margin: 0 auto;
		padding: 8px 14px;
		border-radius: 999px;
		background: #efe7ff;
		color: #6d28d9;
		font-size: 12px;
		font-weight: 800;
