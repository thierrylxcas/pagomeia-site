		letter-spacing: -0.055em;
	}

	.description {
		max-width: 820px;
		margin: 28px auto 0;
		color: #65606a;
		font-size: 20px;
		line-height: 1.7;
	}

	.meta {
		display: flex;
		align-items: center;
		justify-content: center;
		flex-wrap: wrap;
		gap: 24px 38px;
		margin-top: 34px;
	}

	.author {
		display: flex;
		align-items: center;
		gap: 12px;
		text-align: left;
	}

	.author :global(img) {
		width: 44px;
		height: 44px;
		border-radius: 50%;
		object-fit: cover;
		box-shadow: 0 8px 20px rgba(124, 58, 237, 0.18);
	}

	.author span,
	.author strong {
		display: block;
	}

	.author span {
		color: #97919c;
		font-size: 11px;
	}

	.author strong {
		margin-top: 2px;
		color: #28232c;
		font-size: 14px;
	}

	.article-details {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 10px 20px;
		color: #817a86;
		font-size: 13px;
	}

	.hero-image {
		max-width: 1220px;
		margin: 0 auto;
		overflow: hidden;
		border-radius: 28px;
		box-shadow: 0 30px 70px rgba(37, 22, 58, 0.13);
	}

	.hero-image :global(img) {
		display: block;
		width: 100%;
		height: auto;
		aspect-ratio: 16 / 9;
		object-fit: cover;
	}

	.content-wrapper {
		width: min(780px, 100%);
		margin: 0 auto;
		padding: 70px 0 0;
	}

	.prose {
		color: #302b34;
		font-size: 19px;
		line-height: 1.9;
	}

	.prose :global(h1) {
		display: none;
	}

	.prose :global(h2) {
		margin: 58px 0 20px;
		color: #17131b;
		font-size: 38px;
		line-height: 1.12;
		letter-spacing: -0.035em;
	}

	.prose :global(h3) {
		margin: 42px 0 16px;
		color: #17131b;
		font-size: 28px;
		line-height: 1.2;
		letter-spacing: -0.025em;
	}

	.prose :global(p) {
		margin: 0 0 27px;
	}

	.prose :global(strong) {
		color: #18141c;
	}

	.prose :global(a) {
		color: #6d28d9;
		font-weight: 700;
	}

	.prose :global(ul),
	.prose :global(ol) {
		margin: 0 0 30px;
		padding-left: 26px;
	}

	.prose :global(li) {
		margin-bottom: 11px;
		padding-left: 5px;
	}

	.prose :global(blockquote) {
		margin: 40px 0;
		padding: 25px 28px;
		border-left: 4px solid #7c3aed;
		border-radius: 0 16px 16px 0;
		background: #faf7ff;
		color: #514a57;
		font-size: 21px;
		line-height: 1.7;
	}

	.prose :global(img) {
		display: block;
		width: 100%;
		margin: 38px 0;
		border-radius: 20px;
	}

	.prose :global(hr) {
		margin: 50px 0;
		border: 0;
		border-top: 1px solid #ece7f3;
	}

	.youtube-video {
		margin: 50px 0;
		aspect-ratio: 16 / 9;
		overflow: hidden;
		border-radius: 18px;
		box-shadow: 0 20px 45px rgba(0, 0, 0, 0.12);
	}

	.youtube-video iframe {
		width: 100%;
		height: 100%;
		border: 0;
	}

	.tags {
		margin-top: 60px;
		padding-top: 30px;
		border-top: 1px solid #ece7f3;
	}

	.tags-title {
		display: block;
		margin-bottom: 14px;
		color: #837c88;
		font-size: 12px;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.tag-list {
		display: flex;
		flex-wrap: wrap;
		gap: 9px;
	}

	.tag-list span {
		padding: 8px 12px;
		border-radius: 999px;
		background: #f3edff;
		color: #6d28d9;
		font-size: 13px;
		font-weight: 700;
	}

	.related-posts {
		margin-top: 70px;
		padding-top: 42px;
		border-top: 1px solid #ece7f3;
	}

	.related-heading {
		margin-bottom: 28px;
	}

	.related-eyebrow {
		display: block;
		margin-bottom: 9px;
		color: #7c3aed;
		font-size: 11px;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.1em;
	}

	.related-heading h2 {
		margin: 0;
		color: #17131b;
		font-size: 36px;
		line-height: 1.1;
		letter-spacing: -0.04em;
	}

	.related-heading p {
		margin: 12px 0 0;
		color: #817a86;
		font-size: 14px;
		line-height: 1.6;
	}

	.related-featured,
	.related-card {
		color: inherit;
		text-decoration: none;
	}

	.related-featured {
		display: block;
		overflow: hidden;
		border: 1px solid #e9e2f2;
		border-radius: 24px;
		background: #ffffff;
		box-shadow: 0 15px 40px rgba(39, 22, 56, 0.07);
		transition:
			transform 0.3s ease,
			box-shadow 0.3s ease,
			border-color 0.3s ease;
	}

	.related-featured:hover {
		transform: translateY(-5px);
		border-color: #d8c7ee;
		box-shadow: 0 25px 55px rgba(39, 22, 56, 0.13);
	}

	.related-image {
		position: relative;
		overflow: hidden;
		background:
			radial-gradient(
				circle at top right,
				rgba(192, 132, 252, 0.35),
				transparent 45%
			),
			#211529;
	}

	.related-featured .related-image {
		aspect-ratio: 16 / 8;
	}

	.related-card .related-image {
		aspect-ratio: 16 / 9;
	}

	.related-image img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.45s ease;
	}

	.related-featured:hover .related-image img,
	.related-card:hover .related-image img {
		transform: scale(1.055);
	}

	.image-placeholder {
		display: grid;
		width: 100%;
		height: 100%;
		place-items: center;
		color: #ffffff;
		font-size: 50px;
	}

	.featured-content {
		padding: 27px 29px 30px;
	}

	.related-category {
		display: block;
		margin-bottom: 9px;
		color: #7c3aed;
		font-size: 11px;
		font-weight: 900;
		text-transform: uppercase;
		letter-spacing: 0.09em;
		transition: color 0.25s ease;
	}

	.related-featured:hover .related-category,
	.related-card:hover .related-category {
		color: #a855f7;
	}

	.related-featured h3,
	.related-card h3 {
		color: #17131b;
		letter-spacing: -0.035em;
	}

	.related-featured h3 {
		margin: 0;
		font-size: 31px;
		line-height: 1.12;
	}

	.related-featured p {
		margin: 13px 0 0;
		color: #6f6874;
		font-size: 15px;
		line-height: 1.7;
	}

	.related-link {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		margin-top: 20px;
		color: #6d28d9;
		font-size: 13px;
		font-weight: 900;
	}

	.related-link span {
		transition: transform 0.25s ease;
	}

	.related-featured:hover .related-link span,
	.related-card:hover .related-link span {
		transform: translateX(5px);
	}

	.related-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 20px;
		margin-top: 20px;
	}

	.related-card {
		display: flex;
		min-width: 0;
		overflow: hidden;
		flex-direction: column;
		border: 1px solid #e9e2f2;
		border-radius: 20px;
		background: #ffffff;
		box-shadow: 0 12px 30px rgba(39, 22, 56, 0.055);
		transition:
			transform 0.3s ease,
			box-shadow 0.3s ease,
			border-color 0.3s ease;
	}

